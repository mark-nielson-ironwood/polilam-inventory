@model PolilamInventory.Web.ViewModels.EditPlannedPullViewModel
@{
    ViewData["Title"] = "Edit Planned Pull";
}

<h2 class="mb-4">Edit Planned Pull</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card bg-card p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PatternName" />
                <input type="hidden" asp-for="SizeDisplay" />

                <div class="mb-3">
                    <label class="form-label">Pattern</label>
                    <p class="form-control-plaintext text-white">@Model.PatternName</p>
                </div>

                <div class="mb-3">
                    <label class="form-label">Size</label>
                    <p class="form-control-plaintext text-white">@Model.SizeDisplay</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label">Quantity</label>
                    <input asp-for="Quantity" class="form-control" type="number" min="1" required />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ScheduledDate" class="form-label">Scheduled Date</label>
                    <input asp-for="ScheduledDate" class="form-control" type="date" value="@Model.ScheduledDate.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SoNumber" class="form-label">SO Number</label>
                    <input asp-for="SoNumber" class="form-control" required />
                    <span asp-validation-for="SoNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Note" class="form-label">Note <span class="text-muted">(optional)</span></label>
                    <input asp-for="Note" class="form-control" />
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-submit-green flex-grow-1">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
