@model PolilamInventory.Web.ViewModels.AdjustInventoryViewModel
@{
    ViewData["Title"] = "Adjust Inventory";
}

<h2 class="mb-4">Adjust Inventory</h2>

<div class="row">
    <!-- Left: Adjustment form -->
    <div class="col-md-6">
        <div class="card bg-card p-4">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Pattern</label>
                    <select name="PatternId" id="patternSelect" class="form-select" required>
                        <option value="">— Select Pattern —</option>
                        @foreach (var p in Model.Patterns)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                    <span asp-validation-for="PatternId" class="text-danger small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Width</label>
                        <select name="Width" id="widthSelect" class="form-select" required>
                            <option value="">W</option>
                            @foreach (var w in Model.Widths)
                            {
                                <option value="@w" selected="@(w == 60)">@w"</option>
                            }
                        </select>
                        <span asp-validation-for="Width" class="text-danger small"></span>
                    </div>
                    <div class="col">
                        <label class="form-label">Length</label>
                        <select name="Length" id="lengthSelect" class="form-select" required>
                            <option value="">L</option>
                            @foreach (var l in Model.Lengths)
                            {
                                <option value="@l" selected="@(l == 144)">@l"</option>
                            }
                        </select>
                        <span asp-validation-for="Length" class="text-danger small"></span>
                    </div>
                    <div class="col">
                        <label class="form-label">Thickness</label>
                        <select name="Thickness" id="thicknessSelect" class="form-select" required>
                            <option value="">T</option>
                            @foreach (var t in Model.Thicknesses)
                            {
                                <option value="@t">@t"</option>
                            }
                        </select>
                        <span asp-validation-for="Thickness" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Quantity (negative to remove/correct)</label>
                    <input type="number" name="Quantity" id="quantityInput" class="form-control"
                           min="-9999" max="9999" value="@Model.Quantity" required />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input type="date" name="DateAdded" class="form-control"
                           value="@Model.DateAdded.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="DateAdded" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Note <span class="text-muted">(optional)</span></label>
                    <textarea name="Note" class="form-control" rows="2" maxlength="500">@Model.Note</textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" name="IsDrop" value="true" class="form-check-input"
                           id="isDropCheck" @(Model.IsDrop ? "checked" : "") />
                    <label class="form-check-label" for="isDropCheck">
                        This is drop (leftover material — $0 value, excluded from removal report)
                    </label>
                </div>

                <div class="mb-3" id="costPerSheetGroup" style="display:none">
                    <label class="form-label" id="costPerSheetLabel">Price Per Sq Ft</label>
                    <input type="number" name="CostPerSheet" id="costPerSheetInput" class="form-control"
                           step="0.01" min="0" placeholder="$/sqft" />
                    <span asp-validation-for="CostPerSheet" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Save Adjustment</button>
            </form>
        </div>
    </div>

    <!-- Right: Context panel -->
    <div class="col-md-6">
        <div class="card bg-card p-4" id="contextPanel">
            <p class="text-muted">Select a pattern and size to see current inventory.</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var patternSelect    = document.getElementById('patternSelect');
    var widthSelect      = document.getElementById('widthSelect');
    var lengthSelect     = document.getElementById('lengthSelect');
    var thicknessSelect  = document.getElementById('thicknessSelect');
    var quantityInput    = document.getElementById('quantityInput');
    var panel            = document.getElementById('contextPanel');
    var isDropCheck      = document.getElementById('isDropCheck');
    var costGroup        = document.getElementById('costPerSheetGroup');
    var costInput        = document.getElementById('costPerSheetInput');
    var costLabel        = document.getElementById('costPerSheetLabel');

    var currentInventory = null;
    var currentWac = 0;
    var currentWacPerSqFt = 0;
    var hasWacHistory = false;

    function colorClass(n) {
        if (n > 0) return 'text-healthy';
        if (n === 0) return 'text-warning';
        return 'text-negative';
    }

    function updateCostVisibility() {
        if (isDropCheck.checked) {
            costGroup.style.display = 'none';
            costInput.removeAttribute('required');
            costInput.value = '';
        } else {
            costGroup.style.display = 'block';
            if (!hasWacHistory) {
                costLabel.textContent = 'Price Per Sq Ft (required \u2014 no prior cost data)';
                costInput.setAttribute('required', 'required');
                costInput.value = '';
            } else {
                costLabel.textContent = 'Price Per Sq Ft (defaults to current WAC: $' + currentWacPerSqFt.toFixed(2) + '/sqft)';
                costInput.removeAttribute('required');
                if (!costInput.value) {
                    costInput.value = currentWacPerSqFt.toFixed(2);
                }
            }
        }
    }

    function updatePanel() {
        var patternId = patternSelect.value;
        var width     = widthSelect.value;
        var length    = lengthSelect.value;
        var thickness = thicknessSelect.value;

        if (!patternId || !width || !length || !thickness) {
            currentInventory = null;
            currentWac = 0;
            hasWacHistory = false;
            panel.innerHTML = '<p class="text-muted">Select a pattern and size to see current inventory.</p>';
            updateCostVisibility();
            return;
        }

        panel.innerHTML = '<p class="text-muted">Loading...</p>';

        var inventoryUrl = '/Adjustments/GetCurrentInventory?patternId=' + encodeURIComponent(patternId)
            + '&width=' + encodeURIComponent(width)
            + '&length=' + encodeURIComponent(length)
            + '&thickness=' + encodeURIComponent(thickness);

        var wacUrl = '/Adjustments/GetWAC?patternId=' + encodeURIComponent(patternId)
            + '&width=' + encodeURIComponent(width)
            + '&length=' + encodeURIComponent(length)
            + '&thickness=' + encodeURIComponent(thickness);

        Promise.all([
            fetch(inventoryUrl).then(function (r) { return r.json(); }),
            fetch(wacUrl).then(function (r) { return r.json(); })
        ]).then(function (results) {
            currentInventory = results[0].current;
            currentWac = results[1].wac;
            currentWacPerSqFt = results[1].wacPerSqFt;
            hasWacHistory = results[1].hasHistory;
            renderPanel();
            updateCostVisibility();
        }).catch(function () {
            currentInventory = null;
            currentWac = 0;
            hasWacHistory = false;
            panel.innerHTML = '<p class="text-danger small">Failed to load inventory.</p>';
            updateCostVisibility();
        });
    }

    function renderPanel() {
        if (currentInventory === null) return;

        var qty = parseInt(quantityInput.value, 10);
        var html = '<p class="mb-1">Current inventory: <span class="' + colorClass(currentInventory) + ' fw-bold">'
            + currentInventory + ' sheets</span></p>';

        if (hasWacHistory) {
            html += '<p class="mb-1">Current WAC: <span class="fw-bold">$' + currentWac.toFixed(2) + '</span> per sheet (<span class="fw-bold">$' + currentWacPerSqFt.toFixed(2) + '</span>/sqft)</p>';
        } else {
            html += '<p class="mb-1 text-muted">No prior cost data for this combination.</p>';
        }

        if (!isNaN(qty) && quantityInput.value !== '') {
            var after = currentInventory + qty;
            html += '<p class="mb-0">After adjustment: <span class="' + colorClass(after) + ' fw-bold">'
                + after + ' sheets</span></p>';
        }

        panel.innerHTML = html;
    }

    patternSelect.addEventListener('change', updatePanel);
    widthSelect.addEventListener('change', updatePanel);
    lengthSelect.addEventListener('change', updatePanel);
    thicknessSelect.addEventListener('change', updatePanel);
    isDropCheck.addEventListener('change', updateCostVisibility);

    quantityInput.addEventListener('input', function () {
        if (currentInventory !== null) {
            renderPanel();
        }
    });

    // Initialize
    updateCostVisibility();
}());
</script>
}
