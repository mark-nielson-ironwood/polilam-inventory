@model PolilamInventory.Web.ViewModels.RemovalReportViewModel
@{
    ViewData["Title"] = "Removal Report";
}

<h2 class="mb-4">Removal Report</h2>

@* Filter Bar *@
<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label text-muted">Start Date</label>
            <input type="date" name="startDate" class="form-control form-control-sm bg-card text-white border-secondary"
                   value="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-auto">
            <label class="form-label text-muted">End Date</label>
            <input type="date" name="endDate" class="form-control form-control-sm bg-card text-white border-secondary"
                   value="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-auto">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="includeInactive" id="includeInactive" value="true"
                       @(Model.IncludeInactive ? "checked" : "") />
                <label class="form-check-label text-muted" for="includeInactive">Show all patterns (including zero removals)</label>
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary">Apply Filters</button>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="RemovalCsv" asp-route-startDate="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-endDate="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-includeInactive="@Model.IncludeInactive" class="btn btn-sm btn-outline-secondary me-1">Export CSV</a>
            <a asp-action="RemovalPdf" asp-route-startDate="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-endDate="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-includeInactive="@Model.IncludeInactive" class="btn btn-sm btn-outline-secondary">Export PDF</a>
        </div>
    </div>
</form>

@if (!Model.Rows.Any())
{
    <p class="text-muted">No removals in the selected period.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm align-middle">
            <thead>
                <tr>
                    <th>Pattern</th>
                    <th>W×L×T</th>
                    <th class="text-center">Sheets Removed</th>
                    <th>Last Removal Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.PatternName</td>
                        <td>@row.SizeDisplay</td>
                        <td class="text-center @(row.SheetsRemoved == 0 ? "text-muted" : "text-negative")">
                            @row.SheetsRemoved
                        </td>
                        <td>@(row.LastRemovalDate.HasValue ? row.LastRemovalDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
