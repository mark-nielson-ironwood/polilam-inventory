@model PolilamInventory.Web.ViewModels.InventoryReportViewModel
@{
    ViewData["Title"] = "Inventory Report";
}

<h2 class="mb-4">Inventory Report</h2>

@* Filter Bar *@
<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label text-muted">Pattern</label>
            <select name="patternFilter" class="form-select form-select-sm bg-card text-white border-secondary">
                <option value="">All Patterns</option>
                @foreach (var name in Model.PatternNames)
                {
                    <option value="@name" selected="@(Model.PatternFilter == name)">@name</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary">Apply Filters</button>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="InventoryCsv" asp-route-patternFilter="@Model.PatternFilter" class="btn btn-sm btn-outline-secondary me-1">Export CSV</a>
            <a asp-action="InventoryPdf" asp-route-patternFilter="@Model.PatternFilter" class="btn btn-sm btn-outline-secondary">Export PDF</a>
        </div>
    </div>
</form>

@if (!Model.Rows.Any())
{
    <p class="text-muted">No data.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm align-middle">
            <thead>
                <tr>
                    <th>Pattern</th>
                    <th>W×L×T</th>
                    <th class="text-center">In Stock</th>
                    <th>Last Adj.</th>
                    <th class="text-center">On Order</th>
                    <th>Order Date</th>
                    <th>ETA</th>
                    <th class="text-center">Committed Before Arrival</th>
                    <th class="text-center">Projected at Arrival</th>
                    <th class="text-center">Total Committed</th>
                    <th class="text-center">Projected Balance</th>
                    <th>Re-Order?</th>
                    <th class="text-end">Cost/Sheet</th>
                    <th class="text-end">Stock Value</th>
                    <th class="text-end">On Order Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.PatternName</td>
                        <td>@row.SizeDisplay</td>
                        <td class="text-center @(row.InStock < 0 ? "text-negative" : row.InStock <= row.ReorderTrigger ? "text-warning" : "text-healthy")">
                            @row.InStock
                        </td>
                        <td>@(row.LastAdjDate.HasValue ? row.LastAdjDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                        <td class="text-center">@row.OnOrder</td>
                        <td>@(row.OrderDate.HasValue ? row.OrderDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                        <td>@(row.Eta.HasValue ? row.Eta.Value.ToString("yyyy-MM-dd") : "—")</td>
                        <td class="text-center">@row.CommittedBeforeArrival</td>
                        <td class="text-center @(row.ProjectedAtArrival < 0 ? "text-negative" : "")">
                            @row.ProjectedAtArrival
                        </td>
                        <td class="text-center">@row.TotalCommitted</td>
                        <td class="text-center @(row.ProjectedBalance < 0 ? "text-negative" : row.ProjectedBalance <= row.ReorderTrigger ? "text-warning" : "text-healthy")">
                            @row.ProjectedBalance
                        </td>
                        <td>
                            @if (row.NeedsReorder)
                            {
                                <span class="text-warning">Re-order may be needed</span>
                            }
                        </td>
                        <td class="text-end">@(row.SheetValue > 0 ? row.SheetValue.ToString("C2") : "—")</td>
                        <td class="text-end">@(row.SheetValue > 0 ? row.StockValue.ToString("C0") : "—")</td>
                        <td class="text-end">@(row.SheetValue > 0 ? row.OnOrderValue.ToString("C0") : "—")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold">
                    <td colspan="12" class="text-end">Grand Total</td>
                    <td class="text-end">—</td>
                    <td class="text-end">@Model.Rows.Sum(r => r.StockValue).ToString("C0")</td>
                    <td class="text-end">@Model.Rows.Sum(r => r.OnOrderValue).ToString("C0")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}
