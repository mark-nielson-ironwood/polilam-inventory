@model PolilamInventory.Web.ViewModels.TransactionReportViewModel
@{
    ViewData["Title"] = "Transactions Report";
}

<h2 class="mb-4">Transactions Report</h2>

@* Filter Bar *@
<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label text-muted">Pattern</label>
            <select name="patternFilter" class="form-select form-select-sm bg-card text-white border-secondary">
                <option value="">All Patterns</option>
                @foreach (var name in Model.PatternNames)
                {
                    <option value="@name" selected="@(Model.PatternFilter == name)">@name</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label text-muted">Start Date</label>
            <input type="date" name="startDate" class="form-control form-control-sm bg-card text-white border-secondary"
                   value="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-auto">
            <label class="form-label text-muted">End Date</label>
            <input type="date" name="endDate" class="form-control form-control-sm bg-card text-white border-secondary"
                   value="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary">Apply Filters</button>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="TransactionCsv" asp-route-patternFilter="@Model.PatternFilter" asp-route-startDate="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-endDate="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" class="btn btn-sm btn-outline-secondary me-1">Export CSV</a>
            <a asp-action="TransactionPdf" asp-route-patternFilter="@Model.PatternFilter" asp-route-startDate="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" asp-route-endDate="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" class="btn btn-sm btn-outline-secondary">Export PDF</a>
        </div>
    </div>
</form>

@if (!Model.Rows.Any())
{
    <p class="text-muted">No transactions in the selected period.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Pattern</th>
                    <th>W×L×T</th>
                    <th>Qty</th>
                    <th>PO/SO</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.Date.ToString("yyyy-MM-dd")</td>
                        <td>
                            @switch (row.Type)
                            {
                                case "Order":
                                    <span class="badge bg-primary">Order</span>
                                    break;
                                case "Receipt":
                                    <span class="badge bg-success">Receipt</span>
                                    break;
                                case "Pull":
                                    <span class="badge bg-danger">Pull</span>
                                    break;
                                case "Adjustment":
                                    <span class="badge bg-secondary">Adjustment</span>
                                    break;
                                case "Planned":
                                    <span class="badge bg-warning text-dark">Planned</span>
                                    break;
                            }
                        </td>
                        <td>@row.PatternName</td>
                        <td>@row.SizeDisplay</td>
                        <td class="@(row.Quantity < 0 ? "text-negative" : "text-healthy")">
                            @row.Quantity
                        </td>
                        <td>@(row.PoSoNumber ?? "—")</td>
                        <td>@(row.Note ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
