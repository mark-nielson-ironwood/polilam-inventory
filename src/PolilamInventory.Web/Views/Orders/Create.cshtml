@model PolilamInventory.Web.ViewModels.PlaceOrderViewModel
@{
    ViewData["Title"] = "Place Order";
}

<h2 class="mb-4">Place Order</h2>

<div class="row">
    <!-- Left: Order form -->
    <div class="col-md-6">
        <div class="card bg-card p-4">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Pattern</label>
                    <select name="patternId" id="patternSelect" class="form-select" required>
                        <option value="">— Select Pattern —</option>
                        @foreach (var p in Model.Patterns)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Width</label>
                        <select name="width" id="widthSelect" class="form-select" required>
                            <option value="">W</option>
                            @foreach (var w in Model.Widths)
                            {
                                <option value="@w" selected="@(w == 60)">@w"</option>
                            }
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Length</label>
                        <select name="length" id="lengthSelect" class="form-select" required>
                            <option value="">L</option>
                            @foreach (var l in Model.Lengths)
                            {
                                <option value="@l" selected="@(l == 144)">@l"</option>
                            }
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Thickness</label>
                        <select name="thickness" id="thicknessSelect" class="form-select" required>
                            <option value="">T</option>
                            @foreach (var t in Model.Thicknesses)
                            {
                                <option value="@t">@t"</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input type="number" name="quantityOrdered" id="quantityInput" class="form-control" min="1" required />
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Order Date</label>
                        <input type="date" name="orderDate" class="form-control"
                               value="@Model.OrderDate.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col">
                        <label class="form-label">ETA</label>
                        <input type="date" name="etaDate" class="form-control"
                               value="@Model.EtaDate.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">PO Number</label>
                    <input type="text" name="poNumber" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Note <span class="text-muted">(optional)</span></label>
                    <input type="text" name="note" class="form-control" />
                </div>

                <div class="mb-3" id="costPerSqFtGroup" style="display:none">
                    <label class="form-label">Cost Per Sq Ft <span class="text-muted">(auto-filled from pricing table — override if needed)</span></label>
                    <input type="number" name="CostPerSqFt" id="costPerSqFtInput" class="form-control"
                           step="0.01" min="0" placeholder="$/sqft" />
                </div>

                <button type="submit" class="btn btn-submit-green w-100">Place Order</button>
            </form>
        </div>
    </div>

    <!-- Right: Context panel -->
    <div class="col-md-6">
        <div class="card bg-card p-4" id="contextPanel">
            <p class="text-muted">Select a pattern to see current inventory and open orders.</p>
        </div>
        <div class="card bg-card p-4 mt-3" id="pricingPanel" style="display:none">
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var patternSelect   = document.getElementById('patternSelect');
    var widthSelect     = document.getElementById('widthSelect');
    var lengthSelect    = document.getElementById('lengthSelect');
    var thicknessSelect = document.getElementById('thicknessSelect');
    var quantityInput   = document.getElementById('quantityInput');
    var contextPanel    = document.getElementById('contextPanel');
    var pricingPanel    = document.getElementById('pricingPanel');
    var costPerSqFtGroup = document.getElementById('costPerSqFtGroup');
    var costPerSqFtInput = document.getElementById('costPerSqFtInput');

    function updateContext() {
        var patternId = patternSelect.value;
        if (!patternId) {
            contextPanel.innerHTML = '<p class="text-muted">Select a pattern to see current inventory and open orders.</p>';
            return;
        }
        contextPanel.innerHTML = '<p class="text-muted">Loading...</p>';
        fetch('/api/context/pattern/' + patternId)
            .then(function (r) {
                if (!r.ok) throw new Error('API error');
                return r.json();
            })
            .then(function (data) {
                var html = '';

                html += '<h6 class="mb-2">Current Inventory</h6>';
                if (data.inventory.length === 0) {
                    html += '<p class="text-muted small">No inventory records.</p>';
                } else {
                    html += '<table class="table table-dark table-sm"><thead><tr><th>Size</th><th class="text-center">In Stock</th></tr></thead><tbody>';
                    data.inventory.forEach(function (row) {
                        var cls = row.inStock < 0 ? 'text-negative' : row.inStock === 0 ? 'text-muted' : 'text-healthy';
                        html += '<tr><td>' + row.sizeDisplay + '</td><td class="text-center ' + cls + '">' + row.inStock + '</td></tr>';
                    });
                    html += '</tbody></table>';
                }

                html += '<h6 class="mt-3 mb-2">Open Orders</h6>';
                if (data.openOrders.length === 0) {
                    html += '<p class="text-muted small">No open orders.</p>';
                } else {
                    html += '<table class="table table-dark table-sm"><thead><tr><th>PO</th><th>Size</th><th class="text-center">Ordered</th><th class="text-center">Received</th><th class="text-center">Outstanding</th><th>ETA</th></tr></thead><tbody>';
                    data.openOrders.forEach(function (o) {
                        html += '<tr><td>' + o.poNumber + '</td><td>' + o.sizeDisplay + '</td><td class="text-center">' + o.ordered + '</td><td class="text-center">' + o.received + '</td><td class="text-center">' + o.outstanding + '</td><td>' + o.eta + '</td></tr>';
                    });
                    html += '</tbody></table>';
                }

                contextPanel.innerHTML = html;
            })
            .catch(function () {
                contextPanel.innerHTML = '<p class="text-danger small">Failed to load context.</p>';
            });
    }

    function updatePricing() {
        var patternId = patternSelect.value;
        var width     = widthSelect.value;
        var length    = lengthSelect.value;
        var thickness = thicknessSelect.value;
        var quantity  = quantityInput.value;

        if (!patternId || !width || !length || !thickness || !quantity || parseInt(quantity) < 1) {
            pricingPanel.style.display = 'none';
            return;
        }

        fetch('/api/context/pricing?patternId=' + encodeURIComponent(patternId)
            + '&width=' + encodeURIComponent(width)
            + '&length=' + encodeURIComponent(length)
            + '&thickness=' + encodeURIComponent(thickness)
            + '&quantity=' + encodeURIComponent(quantity))
            .then(function (r) {
                if (!r.ok) throw new Error('API error');
                return r.json();
            })
            .then(function (data) {
                if (data.costPerSheet) {
                    pricingPanel.style.display = 'block';
                    pricingPanel.innerHTML = '<h6 class="mb-2">Estimated Cost</h6>'
                        + '<p class="mb-0">Cost per sheet: <span class="fw-bold text-healthy">$' + data.costPerSheet + '</span> ($' + data.costPerSqFt + '/sqft)</p>'
                        + '<p class="text-muted small mb-0">Total: $' + (parseFloat(data.costPerSheet) * parseInt(quantity)).toFixed(2) + '</p>';
                    costPerSqFtGroup.style.display = 'block';
                    costPerSqFtInput.value = data.costPerSqFt;
                } else {
                    pricingPanel.style.display = 'none';
                    costPerSqFtGroup.style.display = 'none';
                }
            })
            .catch(function () {
                pricingPanel.style.display = 'none';
            });
    }

    patternSelect.addEventListener('change', function () { updateContext(); updatePricing(); });
    widthSelect.addEventListener('change', updatePricing);
    lengthSelect.addEventListener('change', updatePricing);
    thicknessSelect.addEventListener('change', updatePricing);
    quantityInput.addEventListener('input', updatePricing);
}());
</script>
}
