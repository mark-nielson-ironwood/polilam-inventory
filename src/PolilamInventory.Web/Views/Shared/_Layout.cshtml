<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Polilam Inventory</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-brand">Polilam Inventory</div>

        <div class="sidebar-section-label">Overview</div>
        <a asp-controller="Dashboard" asp-action="Index"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
            Dashboard
        </a>

        <div class="sidebar-section-label">Transactions</div>
        <a asp-controller="Orders" asp-action="Create"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")">
            Place Order
        </a>
        <a asp-controller="Receipts" asp-action="Create"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Receipts" ? "active" : "")">
            Receive Shipment
        </a>
        <a asp-controller="Pulls" asp-action="Create"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pulls" ? "active" : "")">
            Pull Sheets
        </a>

        <div class="sidebar-section-label">Reports</div>
        <a asp-controller="Reports" asp-action="Inventory"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Inventory" ? "active" : "")">
            Inventory
        </a>
        <a asp-controller="Reports" asp-action="Removal"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Removal" ? "active" : "")">
            Removal
        </a>
        <a asp-controller="Reports" asp-action="Transactions"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Transactions" ? "active" : "")">
            Transactions
        </a>

        <div class="sidebar-section-label">Admin</div>
        <a asp-controller="Settings" asp-action="Index"
           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
            Settings
        </a>
    </nav>

    <!-- Main content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
